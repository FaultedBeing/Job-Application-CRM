{
  "name": "job-tracker-desktop",
  "version": "1.0.7",
  "description": "Desktop wrapper for Job Application Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jobtracker.app",
    "productName": "Job Application Tracker",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "package.json",
      "icon.ico",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server-dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server/node_modules",
        "to": "server-node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../client/dist",
        "to": "client-dist",
        "filter": ["**/*"]
      },
      {
        "from": "icon.ico",
        "to": "."
      },
      {
        "from": "icon.png",
        "to": "."
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
