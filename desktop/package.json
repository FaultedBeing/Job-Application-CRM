{
  "name": "job-tracker-desktop",
  "version": "1.0.8",
  "description": "Desktop wrapper for Job Application Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.jobtracker.app",
    "productName": "Job Application Tracker",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Job Application Tracker",
      "displayLanguageSelector": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "include": "build/installer.nsh",
      "artifactName": "Job Application Tracker Setup ${version}.exe",
      "warningsAsErrors": false
    },
    "files": [
      "main.js",
      "package.json",
      "icon.ico",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server-dist",
        "filter": ["**/*"]
      },
      {
        "from": "../server/node_modules",
        "to": "server-node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../client/dist",
        "to": "client-dist",
        "filter": ["**/*"]
      },
      {
        "from": "icon.ico",
        "to": "."
      },
      {
        "from": "icon.png",
        "to": "."
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
